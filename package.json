{
  "name": "vscope",
  "displayName": "VScope",
  "description": "Fuzzy file search and live grep for VS Code, powered by fzf and ripgrep",
  "version": "0.0.1",
  "publisher": "vedant",
  "icon": "logo.png",
  "license": "MIT",
  "keywords": ["fzf", "fuzzy", "search", "grep", "ripgrep", "files", "finder"],
  "categories": ["Search"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscope.search",
        "title": "VScope: Fuzzy File Search"
      },
      {
        "command": "vscope.grep",
        "title": "VScope: Live Grep"
      }
    ],
    "keybindings": [
      {
        "command": "vscope.search",
        "key": "alt+; f"
      },
      {
        "command": "vscope.grep",
        "key": "alt+; g"
      },
      {
        "command": "vscope.keydown",
        "args": "moveDown",
        "key": "ctrl+n",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "moveUp",
        "key": "ctrl+p",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewDown",
        "key": "ctrl+d",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewUp",
        "key": "ctrl+u",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewLeft",
        "key": "ctrl+f",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewRight",
        "key": "ctrl+k",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "zoomLeft",
        "key": "alt+,",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "zoomRight",
        "key": "alt+.",
        "when": "vscope.active"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "shiki": "^4.0.2"
  }
}
