{
  "name": "vscope",
  "displayName": "VScope",
  "description": "Fuzzy file search for VS Code, powered by fzf",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscope.search",
        "title": "VScope: Fuzzy File Search"
      },
      {
        "command": "vscope.grep",
        "title": "VScope: Live Grep"
      }
    ],
    "keybindings": [
      {
        "command": "vscope.search",
        "key": "alt+shift+f",
        "mac": "alt+shift+f"
      },
      {
        "command": "vscope.grep",
        "key": "alt+shift+g",
        "mac": "alt+shift+g"
      },
      {
        "command": "vscope.keydown",
        "args": "moveDown",
        "key": "ctrl+n",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "moveUp",
        "key": "ctrl+p",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewDown",
        "key": "ctrl+d",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewUp",
        "key": "ctrl+u",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewLeft",
        "key": "ctrl+f",
        "when": "vscope.active"
      },
      {
        "command": "vscope.keydown",
        "args": "previewRight",
        "key": "ctrl+k",
        "when": "vscope.active"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
