{
  "name": "vscope",
  "displayName": "VScope",
  "description": "Fuzzy file search for VS Code, powered by fzf",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscope.search",
        "title": "VScope: Fuzzy File Search"
      }
    ],
    "keybindings": [
      {
        "command": "vscope.search",
        "key": "alt+shift+f",
        "mac": "alt+shift+f"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
